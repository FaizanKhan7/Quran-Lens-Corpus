{
  "name": "quran-lens",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "corpus:download": "dotenv -e .env.local -- tsx scripts/download-corpus.ts",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "db:seed:dry": "dotenv -e .env.local -- tsx scripts/seed.ts --dry-run",
    "db:seed:treebank": "dotenv -e .env.local -- tsx scripts/seed-treebank.ts",
    "db:seed:ontology": "dotenv -e .env.local -- tsx scripts/seed-ontology.ts",
    "db:reset": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "es:up": "docker compose up -d elasticsearch",
    "es:index": "dotenv -e .env.local -- tsx scripts/index-elasticsearch.ts",
    "es:index:words": "dotenv -e .env.local -- tsx scripts/index-elasticsearch.ts --index=words",
    "es:index:roots": "dotenv -e .env.local -- tsx scripts/index-elasticsearch.ts --index=roots",
    "es:index:verses": "dotenv -e .env.local -- tsx scripts/index-elasticsearch.ts --index=verses",
    "es:reindex": "dotenv -e .env.local -- tsx scripts/index-elasticsearch.ts --drop"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@serwist/next": "^9.5.7",
    "@types/d3": "^7.4.3",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "geist": "^1.7.0",
    "idb": "^8.0.3",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "serwist": "^9.5.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
